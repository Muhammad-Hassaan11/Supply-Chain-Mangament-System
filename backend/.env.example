# Supply Chain DBMS - Backend Configuration Template

# Server Config
PORT=8000
HOST=127.0.0.1

# CORS (Frontend Origins)
# For Vercel production, set your deployed frontend URL here (comma-separated):
# Example: CORS_ORIGINS=https://supply-chain-mangament-system.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: allow all Vercel preview deployments (use with caution)
CORS_ORIGIN_REGEX=^https://([a-zA-Z0-9-]+\\.)?(vercel\\.app|ngrok-free\\.app|trycloudflare\\.com)$

# Database Configuration (SQL Server)
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost
DB_DATABASE=SupplyChainDB
DB_TRUSTED_CONNECTION=yes
# DB_USERNAME=sa
# DB_PASSWORD=your_password

# Authentication (JWT)
JWT_SECRET_KEY=generate_your_own_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Registration Verification Code
ADMIN_REGISTRATION_SECRET=your_admin_secret_here
